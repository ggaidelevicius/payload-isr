{
  "name": "@ggaidelevicius/payload-isr",
  "version": "1.1.3",
  "description": "Payload CMS plugin for ISR-style path revalidation with optional full rebuild fallback",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:types && pnpm build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "hooks:install": "git config core.hooksPath .githooks",
    "lint": "eslint",
    "lint:fix": "eslint ./src --fix",
    "test": "pnpm test:int",
    "test:int": "vitest dev/int.spec.ts dev/plugin.spec.ts",
    "prepack": "pnpm clean && pnpm build",
    "prepublishOnly": "pnpm test",
    "pack:dry-run": "pnpm pack --dry-run",
    "publish:check": "pnpm test && pnpm build && pnpm pack --dry-run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@payloadcms/db-mongodb": "3.79.0",
    "@payloadcms/db-postgres": "3.79.0",
    "@payloadcms/db-sqlite": "3.79.0",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/next": "3.79.0",
    "@payloadcms/richtext-lexical": "3.79.0",
    "@payloadcms/ui": "3.79.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.8.0",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "copyfiles": "2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "eslint-config-next": "16.1.6",
    "graphql": "^16.13.1",
    "mongodb-memory-server": "11.0.1",
    "next": "16.1.6",
    "open": "^11.0.0",
    "payload": "3.79.0",
    "prettier": "^3.8.1",
    "qs-esm": "7.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "sharp": "0.34.5",
    "sort-package-json": "^3.6.1",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  },
  "peerDependencies": {
    "payload": "^3.37.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "registry": "https://registry.npmjs.org/",
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "isr",
    "revalidation",
    "nextjs",
    "vercel"
  ],
  "author": "Gus Gaidelevicius",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggaidelevicius/payload-isr.git"
  },
  "bugs": {
    "url": "https://github.com/ggaidelevicius/payload-isr/issues"
  },
  "homepage": "https://github.com/ggaidelevicius/payload-isr#readme"
}
